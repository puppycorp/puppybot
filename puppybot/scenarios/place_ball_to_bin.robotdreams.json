{
  "id": "puppybot-ball-to-bin",
  "name": "PuppyBot Ball To Bin",
  "robotId": "puppybot",
  "volumes": [
    {
      "id": "bin_drop_zone",
      "shape": {
        "type": "box",
        "center": [0.157243, 0.075899, 0.285],
        "size": [0.15, 0.15, 0.08]
      }
    },
    {
      "id": "bin_success_volume",
      "shape": {
        "type": "box",
        "center": [0.157243, 0.075899, 0.125],
        "size": [0.15, 0.15, 0.22]
      }
    }
  ],
  "steps": [
    {
      "id": "attach-ball",
      "when": {
        "type": "frameNearObject",
        "frame": "tcp",
        "object": "ball",
        "distanceM": 0.035
      },
      "actions": [
        {
          "type": "attachObject",
          "object": "ball",
          "frame": "tcp"
        }
      ]
    },
    {
      "id": "release-ball",
      "when": {
        "type": "all",
        "conditions": [
          {
            "type": "objectAttached",
            "object": "ball"
          },
          {
            "type": "frameInsideVolume",
            "frame": "tcp",
            "volume": "bin_drop_zone"
          }
        ]
      },
      "actions": [
        {
          "type": "detachObject",
          "object": "ball"
        }
      ]
    }
  ],
  "success": {
    "type": "all",
    "conditions": [
      {
        "type": "objectDetached",
        "object": "ball"
      },
      {
        "type": "objectInsideVolume",
        "object": "ball",
        "volume": "bin_success_volume"
      }
    ]
  }
}
